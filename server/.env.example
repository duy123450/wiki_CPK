# ─── Core ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
FRONTEND_URL=http://localhost:5173

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# For TLS (Render/Upstash): REDIS_URL=rediss://<user>:<password>@host:port

# ─── Session & JWT ──────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_32_char_random_string_here
JWT_ACCESS_SECRET=change_me_to_32_char_random_string_here
JWT_REFRESH_SECRET=change_me_to_32_char_random_string_here
JWT_ACCESS_LIFETIME=15m
JWT_REFRESH_LIFETIME=30d

# ─── Cloudinary ─────────────────────────────────────────────────────────────────
CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret

# ─── Google OAuth (optional) ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/wiki/auth/google/callback

# ─── X (Twitter) OAuth (optional) ───────────────────────────────────────────────
X_LOCAL_CLIENT_ID=your_twitter_client_id
X_LOCAL_CLIENT_SECRET=your_twitter_client_secret
X_LOCAL_CALLBACK_URL=http://127.0.0.1:3000/api/v1/wiki/auth/x/callback
# X_PROD_CLIENT_ID=
# X_PROD_CLIENT_SECRET=
# X_PROD_CALLBACK_URL=

# ─── Discord OAuth (optional) ───────────────────────────────────────────────────
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_LOCAL_CALLBACK_URL=http://localhost:3000/api/v1/wiki/auth/discord/callback
# DISCORD_PROD_CLIENT_ID=
# DISCORD_PROD_CLIENT_SECRET=
# DISCORD_PROD_CALLBACK_URL=

# ─── GitHub OAuth (optional) ────────────────────────────────────────────────────
GITHUB_LOCAL_CLIENT_ID=your_github_client_id
GITHUB_LOCAL_CLIENT_SECRET=your_github_client_secret
GITHUB_LOCAL_CALLBACK_URL=http://localhost:3000/api/v1/wiki/auth/github/callback
# GITHUB_PROD_CLIENT_ID=
# GITHUB_PROD_CLIENT_SECRET=
# GITHUB_PROD_CALLBACK_URL=

# ─── Minimal local setup (skip OAuth) ───────────────────────────────────────────
# You can omit all OAuth keys above to run without social login.
# Redis is optional — app degrades gracefully (no caching, no session store).
# Required for first run: MONGO_URI, SESSION_SECRET, JWT_ACCESS_SECRET, JWT_REFRESH_SECRET
